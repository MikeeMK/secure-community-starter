{
  "name": "secure-community-starter",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm -C apps/api prisma:generate",
    "db:migrate": "pnpm -C apps/api prisma:migrate",
    "db:seed": "pnpm -C apps/api prisma:seed",
    "db:studio": "pnpm -C apps/api prisma:studio"
  }
}